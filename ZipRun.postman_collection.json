{
  "info": {
    "name": "ZipRun — AI Reassignment Engine",
    "description": "Complete API test suite for ZipRun backend. Covers happy paths, edge cases, and the full agentic re-planning loop.\n\nSetup:\n1. Set the `baseUrl` variable to `http://localhost:8080`\n2. Run the seed script or start the app with `create-drop` so data.sql loads\n3. Execute folders in order for the full agentic loop demo",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "createdOrderId", "value": "", "type": "string" },
    { "key": "createdSuggestionId", "value": "", "type": "string" }
  ],
