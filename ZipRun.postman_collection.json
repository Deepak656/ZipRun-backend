    {
      "name": "05 — Agentic Loop (Full End-to-End)",
      "description": "Run these requests in order to demo the full agentic re-planning loop for the walkthrough.\n\nStory: AGT-005 has 3 orders (ORD-004, ORD-005, ORD-006). They go OFFLINE. The system automatically creates PENDING suggestions for all 3 orders without ops doing anything. Ops then reviews them.",
      "item": [
        {
          "name": "Step 1 — Confirm AGT-005 has active orders",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/orders?status=ASSIGNED",
              "host": ["{{baseUrl}}"], "path": ["api","orders"],
              "query": [{ "key": "status", "value": "ASSIGNED" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('AGT-005 has ASSIGNED orders', () => {",
                  "  const agt005Orders = pm.response.json().data.filter(o => o.assignedAgentId === 'AGT-005');",
                  "  pm.expect(agt005Orders.length).to.be.above(0);",
                  "  console.log('AGT-005 active orders:', agt005Orders.map(o => o.id).join(', '));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Step 2 — PATCH AGT-005 to OFFLINE (triggers agentic loop)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/agents/AGT-005/status", "host": ["{{baseUrl}}"], "path": ["api","agents","AGT-005","status"] },
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"OFFLINE\"\n}" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 — returns immediately', () => pm.response.to.have.status(200));",
                  "pm.test('Agent is now OFFLINE', () => {",
                  "  pm.expect(pm.response.json().data.status).to.equal('OFFLINE');",
                  "});",
                  "pm.test('Response time is fast (re-planning is async)', () => {",
                  "  pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});",
                  "console.log('Re-planning loop has been triggered. Wait 2-5 seconds, then run Step 3.');"
                ]
              }
            }
          ]
        },
        {
          "name": "Step 3 — Poll for PENDING suggestions (wait 2-5s after Step 2)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/suggestions?status=PENDING",
              "host": ["{{baseUrl}}"], "path": ["api","suggestions"],
              "query": [{ "key": "status", "value": "PENDING" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const suggestions = pm.response.json().data;",
                  "const agenticSuggestions = suggestions.filter(s => s.triggerReason === 'AGENT_OFFLINE');",
                  "pm.test('Agentic re-plan suggestions are present', () => {",
                  "  pm.expect(agenticSuggestions.length).to.be.above(0);",
                  "  console.log('Auto-generated suggestions for offline agent:', agenticSuggestions.length);",
                  "});",
                  "pm.test('All agentic suggestions are PENDING', () => {",
                  "  agenticSuggestions.forEach(s => pm.expect(s.status).to.equal('PENDING'));",
                  "});",
                  "pm.test('Reasoning is populated by AI or rule fallback', () => {",
                  "  agenticSuggestions.forEach(s => {",
                  "    pm.expect(s.reasoning).to.be.a('string').and.not.empty;",
                  "    pm.expect(s.recommendedAgentId).to.be.a('string');",
                  "  });",
                  "});",
                  "// Save first agentic suggestion ID for Step 4",
                  "if (agenticSuggestions.length > 0) {",
                  "  pm.collectionVariables.set('agenticSuggestionId', agenticSuggestions[0].id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Step 4 — Accept first agentic suggestion",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/suggestions/{{agenticSuggestionId}}", "host": ["{{baseUrl}}"], "path": ["api","suggestions","{{agenticSuggestionId}}"] },
            "body": { "mode": "raw", "raw": "{\n  \"decision\": \"ACCEPT\"\n}" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Suggestion accepted — order reassigned', () => {",
                  "  const s = pm.response.json().data;",
                  "  pm.expect(s.status).to.equal('ACCEPTED');",
                  "  pm.expect(s.reviewedAt).to.not.be.null;",
                  "  pm.expect(s.triggerReason).to.equal('AGENT_OFFLINE');",
                  "  console.log('Order', s.orderId, 'reassigned to agent', s.recommendedAgentId);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Step 5 — Verify order is now REASSIGNED",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/orders?status=REASSIGNED",
              "host": ["{{baseUrl}}"], "path": ["api","orders"],
              "query": [{ "key": "status", "value": "REASSIGNED" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('At least one REASSIGNED order exists', () => {",
                  "  pm.expect(pm.response.json().data.length).to.be.above(0);",
                  "  console.log('REASSIGNED orders:', pm.response.json().data.map(o => o.id).join(', '));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Step 6 — Idempotency check (PATCH AGT-005 OFFLINE again)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/agents/AGT-005/status", "host": ["{{baseUrl}}"], "path": ["api","agents","AGT-005","status"] },
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"OFFLINE\"\n}" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "console.log('Fired OFFLINE again. Wait 3s, then check Step 7 — no duplicate PENDING suggestions should appear.');"
                ]
              }
            }
          ]
        },
        {
          "name": "Step 7 — Verify no duplicate PENDING AGENT_OFFLINE suggestions",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/suggestions?status=PENDING",
              "host": ["{{baseUrl}}"], "path": ["api","suggestions"],
              "query": [{ "key": "status", "value": "PENDING" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const suggestions = pm.response.json().data;",
                  "",
                  "// Group by orderId — no order should have more than one PENDING AGENT_OFFLINE suggestion",
                  "const grouped = {};",
                  "suggestions.filter(s => s.triggerReason === 'AGENT_OFFLINE').forEach(s => {",
                  "  grouped[s.orderId] = (grouped[s.orderId] || 0) + 1;",
                  "});",
                  "",
                  "pm.test('No order has duplicate PENDING AGENT_OFFLINE suggestions (idempotency)', () => {",
                  "  Object.entries(grouped).forEach(([orderId, count]) => {",
                  "    pm.expect(count, `Order ${orderId} has ${count} duplicate PENDING suggestions`).to.equal(1);",
                  "  });",
                  "});"
                ]
              }
            }
          ]
        }
      ]
