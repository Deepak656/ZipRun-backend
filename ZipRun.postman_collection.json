    {
      "name": "03 — On-demand Suggestions",
      "item": [
        {
          "name": "POST generate suggestion — INITIAL trigger",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/orders/ORD-001/suggest", "host": ["{{baseUrl}}"], "path": ["api","orders","ORD-001","suggest"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"triggerReason\": \"INITIAL\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Suggestion returned with expected fields', () => {",
                  "  const s = pm.response.json().data;",
                  "  pm.expect(s.id).to.be.a('string');",
                  "  pm.expect(s.orderId).to.equal('ORD-001');",
                  "  pm.expect(s.status).to.equal('PENDING');",
                  "  pm.expect(s.triggerReason).to.equal('INITIAL');",
                  "  pm.expect(s.confidence).to.be.a('number');",
                  "  pm.expect(s.reasoning).to.be.a('string').and.not.empty;",
                  "  pm.expect(s.recommendedAgentId).to.be.a('string');",
                  "  pm.collectionVariables.set('createdSuggestionId', s.id);",
                  "});"
                ]
              }
            }
          ]
        },
